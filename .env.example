# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=hotlead
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hotlead
DATABASE_URL=postgresql+asyncpg://hotlead:CHANGE_ME@postgres:5432/hotlead

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security (generate: openssl rand -hex 32) ──────────────────────────────
SECRET_KEY=CHANGE_ME
API_KEY=CHANGE_ME

# ── CORS (comma-separated, production: your domain) ────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Scraper tuning ─────────────────────────────────────────────────────────
CELERY_WORKERS=2
IG_REQUEST_DELAY_MIN=1.0
IG_REQUEST_DELAY_MAX=3.0
IG_MAX_REQUESTS_PER_HOUR=200
IG_COOLDOWN_MINUTES=30

# ── Frontend ───────────────────────────────────────────────────────────────
# PUBLIC url of the API, reachable from the user's browser (NOT the internal
# docker hostname). Baked into the client bundle at build time.
#   • production: https://api.your-domain.com
#   • local docker compose: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
